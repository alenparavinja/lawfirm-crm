# terraform.tfvars.example
# Copy to terraform.tfvars and fill in values. Do NOT commit terraform.tfvars.

aws_region   = "us-east-1"
environment  = "dev"

vpc_cidr             = "10.0.0.0/16"
public_subnet_cidr   = "10.0.1.0/24"
private_subnet_cidr  = "10.0.2.0/24"
availability_zone    = "us-east-1a"

bastion_instance_type = "t3.micro"
app_instance_type     = "t3.micro"
db_instance_type      = "t3.micro"

# Key Pair name from EC2 console (no .pem extension).
key_pair_name = "lawfirm-crm-key"

# Operator IP. Get from: https://checkip.amazonaws.com
your_ip_cidr = "YOUR.PUBLIC.IP.HERE/32"
